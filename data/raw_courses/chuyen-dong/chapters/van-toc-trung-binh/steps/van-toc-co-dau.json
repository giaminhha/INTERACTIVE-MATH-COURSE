                        "options": [
                            {
                                "value": "a",
                                "label": "Tại cực đại hoặc cực tiểu cục bộ của $f$."
                            },
                            {
                                "value": "b",
                                "label": "Tại giao điểm của $f$ với trục hoành."
                            },
                            {
                                "value": "c",
                                "label": "Cả A và B."
                            },
                            {
                                "value": "d",
                                "label": "Không bao giờ — dấu vận tốc không đổi trên đường cong trơn."
                            }
                        ],
                        "correct": "a",
                        "explanation": "Vận tốc = 0 và đổi dấu tại cực đại/cực tiểu cục bộ (đỉnh/đáy) của $f$."
                    }
                }
            ]
        },
        {
