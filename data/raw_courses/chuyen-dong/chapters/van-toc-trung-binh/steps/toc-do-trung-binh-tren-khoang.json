                                        "width": 2
                                    }
                                ],
                                "approachPoint": {
                                    "x": "p",
                                    "label": "b"
                                },
                                "annotations": [
                                    {
                                        "type": "limitValue",
                                        "expr": "4/Math.sqrt(p)",
                                        "at": "p",
                                        "label": "Tốc độ trung bình = {value} m/s",
                                        "color": "#ef4444"
                                    }
                                ],
                                "prompt": "Đường xanh = quãng đường thực tế (vật đi nhanh lúc đầu, chậm dần). Đường đỏ nét đứt = nếu vật đi đều suốt từ đầu đến cuối — hai đường gặp nhau tại điểm cuối. Kéo thanh trượt để thay đổi thời điểm. Tốc độ trung bình thay đổi thế nào?"
                            },
                            "reflections": [
                                {
                                    "id": "short",
                                    "trigger": "state.currentValue < 1.5",
                                    "text": "Trong {eval:Math.round(p*10)/10} giây đầu, vật đi rất nhanh. Tốc độ trung bình = {eval:Math.round(4/Math.sqrt(p)*10)/10} m/s — cao vì vật mới xuất phát, chưa chậm lại nhiều."
                                },
                                {
                                    "id": "medium",
                                    "trigger": "state.currentValue >= 1.5 && state.currentValue <= 4",
                                    "text": "Sau {eval:Math.round(p*10)/10} giây, tốc độ trung bình = {eval:Math.round(4/Math.sqrt(p)*10)/10} m/s. Vật đi chậm dần nên trung bình bị kéo xuống so với lúc đầu. Đường đỏ thoải hơn."
                                },
                                {
                                    "id": "long",
                                    "trigger": "state.currentValue > 4",
                                    "text": "Khoảng dài {eval:Math.round(p*10)/10} giây — tốc độ trung bình chỉ còn {eval:Math.round(4/Math.sqrt(p)*10)/10} m/s. Con số này gộp cả lúc nhanh (đầu) và lúc chậm (cuối) thành một giá trị duy nhất — nó che giấu mọi biến thiên bên trong."
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "order_index": 1,
            "blocks": [
                {
                    "id": "text-toc-do-tb-dinh-nghia",
                    "type": "text",
                    "content": {
                        "heading": "Tốc độ trung bình: một con số, một đường thẳng",
                        "paragraphs": [
                            "Quãng đường thực tế $f(t) = 4\\sqrt{t}$ là đường cong — vật đi nhanh lúc đầu rồi chậm dần. Tốc độ trung bình trên $[0, b]$ = $\\frac{f(b)}{b} = \\frac{4\\sqrt{b}}{b} = \\frac{4}{\\sqrt{b}}$.",
                            "Đường đỏ nét đứt trong tương tác vừa rồi là đường thẳng biểu diễn: <i>nếu vật đi đều suốt với tốc độ trung bình thì sẽ đến cùng vị trí</i>. Hai đường gặp nhau tại thời điểm $b$ — nhưng ở giữa chúng rất khác nhau."
                        ]
                    }
                }
            ]
        },
        {
            "order_index": 2,
            "blocks": [
                {
                    "id": "text-toc-do-tb-gioi-han",
                    "type": "text",
                    "content": {
                        "heading": "Tốc độ trung bình che giấu điều gì?",
                        "paragraphs": [
                            "Khi b = 1: tốc độ TB = 4 m/s. Khi b = 4: tốc độ TB = 2 m/s. Cùng một chuyến đi nhưng xét khoảng khác nhau thì được con số khác nhau. Tốc độ trung bình phụ thuộc vào khoảng bạn chọn.",
                            "Tốc độ trung bình trả lời: \"trung bình mỗi giây đi được bao xa?\" — nó gộp cả lúc nhanh lẫn lúc chậm. Nó <b>không</b> cho biết vật đang làm gì tại một thời điểm cụ thể. Hai câu hỏi khác nhau sẽ cần công cụ khác nhau."
                        ]
                    }
                }
            ]
        },
        {
            "order_index": 3,
            "blocks": [
                {
                    "id": "quiz-l4-1",
                    "type": "quiz",
                    "content": {
                        "question": "Vật đi 12 m trong 4 giây không đổi chiều. Tốc độ trung bình?",
                        "options": [
                            {
                                "value": "a",
                                "label": "48 m/s"
                            },
                            {
                                "value": "b",
                                "label": "8 m/s"
                            },
                            {
                                "value": "c",
                                "label": "3 m/s"
                            },
                            {
                                "value": "d",
                                "label": "0.33 m/s"
                            }
                        ],
                        "correct": "c",
                        "explanation": "$12 \\div 4 = 3$ m/s."
                    }
                }
            ]
        },
        {
            "order_index": 4,
            "blocks": [
                {
                    "id": "quiz-l4-2",
                    "type": "quiz",
                    "content": {
                        "question": "Vật đi 7 m về phía trước rồi 3 m về phía sau trong 5 giây. Tốc độ trung bình?",
                        "options": [
                            {
                                "value": "a",
                                "label": "0.8 m/s"
                            },
                            {
                                "value": "b",
                                "label": "2 m/s"
                            },
                            {
                                "value": "c",
                                "label": "4 m/s"
                            },
                            {
                                "value": "d",
                                "label": "1.4 m/s"
                            }
                        ],
                        "correct": "b",
                        "explanation": "Tổng quãng đường = 10 m; tốc độ trung bình = $10 \\div 5 = 2$ m/s."
                    }
                }
            ]
        },
        {
            "order_index": 5,
            "blocks": [
                {
                    "id": "quiz-l4-3",
                    "type": "quiz",
                    "content": {
                        "question": "Trên $[0, 6]$, tốc độ TB = 1.5 m/s. Trên $[0, 3]$, tốc độ TB cũng = 1.5 m/s. Kết luận gì?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Vật đi đều suốt $[0, 6]$."
                            },
                            {
                                "value": "b",
                                "label": "Hai nửa $[0, 3]$ và $[3, 6]$ là hành trình giống hệt nhau."
                            },
                            {
                                "value": "c",
                                "label": "Tốc độ trung bình bằng nhau trên các khoảng khác nhau không suy ra chuyển động giống nhau."
                            },
                            {
                                "value": "d",
                                "label": "Vật đứng yên trong $[3, 6]$."
                            }
                        ],
                        "correct": "c",
                        "explanation": "Cùng giá trị trung bình không đảm bảo cùng hành trình — trung bình che giấu biến thiên."
                    }
                }
            ]
        },
        {
            "order_index": 6,
            "blocks": [
                {
                    "id": "quiz-l4-4",
                    "type": "quiz",
                    "content": {
                        "question": "$f(0)=0$, $f(2)=6$, $f(4)=6$, $f(6)=0$. Tốc độ trung bình trên $[0, 6]$?",
                        "options": [
                            {
                                "value": "a",
                                "label": "0 m/s"
                            },
                            {
                                "value": "b",
                                "label": "1 m/s"
                            },
                            {
                                "value": "c",
                                "label": "2 m/s"
                            },
                            {
                                "value": "d",
                                "label": "3 m/s"
                            }
                        ],
                        "correct": "c",
                        "explanation": "Quãng đường: $0→6 = 6$ m, $6→6 = 0$ m, $6→0 = 6$ m. Tổng = 12 m. $12 \\div 6 = 2$ m/s."
                    }
                }
            ]
        },
        {
            "order_index": 7,
            "blocks": [
                {
                    "id": "quiz-l4-5",
                    "type": "quiz",
                    "content": {
                        "question": "Công thức nào tính tốc độ trung bình trên $[a, b]$?",
                        "options": [
                            {
                                "value": "a",
                                "label": "$f(b) - f(a)$"
                            },
                            {
                                "value": "b",
                                "label": "$\\frac{f(b) + f(a)}{2}$"
                            },
                            {
                                "value": "c",
                                "label": "Tổng quãng đường trên $[a, b]$ chia cho $(b - a)$"
                            },
                            {
                                "value": "d",
                                "label": "$\\frac{f(b)}{b}$"
                            }
                        ],
                        "correct": "c",
                        "explanation": "Tốc độ trung bình dùng tổng quãng đường (không dấu), không phải độ dịch chuyển."
                    }
                }
            ]
        },
        {
            "order_index": 8,
            "blocks": [
                {
                    "id": "quiz-l4-6",
                    "type": "quiz",
                    "content": {
                        "question": "Khi nào tốc độ trung bình trên $[a, b]$ bằng 0?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Khi vật đổi chiều đúng một lần."
                            },
                            {
                                "value": "b",
                                "label": "Khi $f(a) = f(b)$."
                            },
                            {
                                "value": "c",
                                "label": "Khi vật hoàn toàn không di chuyển — tổng quãng đường = 0."
                            },
                            {
                                "value": "d",
                                "label": "Khi $b - a = 0$."
                            }
                        ],
                        "correct": "c",
                        "explanation": "$f(a) = f(b)$ chỉ nghĩa là dịch chuyển = 0, không phải quãng đường = 0. Vật có thể đã đi-về."
                    }
                }
            ]
        },
        {
            "order_index": 9,
            "blocks": [
                {
                    "id": "quiz-l4-7",
                    "type": "quiz",
                    "content": {
                        "question": "Vật X đi 20 m trong 5 s. Vật Y đi 30 m trong 9 s. Vật nào có tốc độ trung bình lớn hơn?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Y: 3.33 m/s > X: 4 m/s."
                            },
                            {
                                "value": "b",
                                "label": "Bằng nhau."
                            },
                            {
                                "value": "c",
                                "label": "X: 4 m/s > Y: 3.33 m/s."
                            },
                            {
                                "value": "d",
                                "label": "Không xác định được nếu không biết hướng."
                            }
                        ],
                        "correct": "c",
                        "explanation": "$X: 20 \\div 5 = 4$ m/s. $Y: 30 \\div 9 \\approx 3.33$ m/s."
                    }
                }
            ]
        },
        {
            "order_index": 10,
            "blocks": [
                {
                    "id": "quiz-l4-8",
                    "type": "quiz",
                    "content": {
                        "question": "Xe tiêu thụ 8 lít/100 km trên chuyến đi 200 km. Đây là ví dụ về:",
                        "options": [
                            {
                                "value": "a",
                                "label": "Tốc độ tiêu thụ tức thời."
                            },
                            {
                                "value": "b",
                                "label": "Tốc độ tiêu thụ trung bình trên khoảng hành trình."
                            },
                            {
                                "value": "c",
                                "label": "Mức tiêu thụ tối đa tại mỗi thời điểm."
                            },
                            {
                                "value": "d",
                                "label": "Tổng nhiên liệu đã dùng."
                            }
                        ],
                        "correct": "b",
                        "explanation": "Tốc độ trung bình và tốc độ tiêu thụ trung bình là cùng cấu trúc: tổng lượng / khoảng."
                    }
                }
            ]
        },
        {
            "order_index": 11,
            "blocks": [
                {
                    "id": "quiz-l4-9",
                    "type": "quiz",
                    "content": {
                        "question": "Tại sao tốc độ trung bình là phép đo \"thô\"?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Chỉ tính được cho chuyển động tốc độ không đổi."
                            },
                            {
                                "value": "b",
                                "label": "Dùng quãng đường, luôn dương."
                            },
                            {
                                "value": "c",
                                "label": "Nó nén toàn bộ hành trình thành một con số, che giấu mọi biến thiên tốc độ bên trong khoảng."
                            },
                            {
                                "value": "d",
                                "label": "Cần biết $f(t)$ tại mọi điểm."
                            }
