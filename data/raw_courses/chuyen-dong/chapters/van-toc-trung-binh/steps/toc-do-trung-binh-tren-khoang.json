                        "interactionType": "B",
                        "lesson": {
                            "interactionType": "B",
                            "meta": {
                                "parameterLabel": "Thời điểm kết thúc (giây)"
                            },
                            "parameter": {
                                "min": 0.5,
                                "max": 6,
                                "initial": 3
                            },
                            "system": {
