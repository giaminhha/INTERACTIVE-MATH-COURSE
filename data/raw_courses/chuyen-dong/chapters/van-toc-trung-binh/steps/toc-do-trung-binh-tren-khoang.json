                                },
                                "curves": [
                                    {
                                        "expr": "4*Math.sqrt(x)",
                                        "label": "Quãng đường thực tế",
                                        "color": "#3b82f6",
                                        "style": "solid",
                                        "width": 2
                                    },
                                    {
                                        "expr": "4/Math.sqrt(p)*x",
                                        "label": "Nếu đi đều (tốc độ trung bình)",
                                        "color": "#ef4444",
