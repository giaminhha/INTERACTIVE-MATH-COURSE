                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "order_index": 1,
            "blocks": [
                {
                    "id": "text-toc-do-kd",
                    "type": "text",
                    "content": {
                        "heading": "Tốc độ không đổi: đồ thị thẳng",
                        "paragraphs": [
                            "Đường xanh $f(t) = 2t$ là hàm tuyến tính. Độ dốc của đường thẳng là <b>tốc độ</b> của vật — và độ dốc này không thay đổi. Mỗi giây, vật đi thêm đúng 2 m. Không tăng tốc, không giảm tốc.",
                            "Cát tuyến trên bất kỳ khoảng nào của đường thẳng đều cho cùng độ dốc — vận tốc trung bình không phụ thuộc vào khoảng bạn chọn."
                        ]
                    }
                }
            ]
        },
        {
            "order_index": 2,
            "blocks": [
                {
                    "id": "text-toc-do-td",
                    "type": "text",
                    "content": {
                        "heading": "Tốc độ thay đổi: đồ thị cong",
                        "paragraphs": [
                            "Đường cam $g(t) = \\frac{1}{2}at^2$ là parabol. Không một đường thẳng nào có thể mô tả đường cong này trọn vẹn. Nơi đường cam dốc hơn, vật đang đi nhanh hơn. Đường cong là bằng chứng học viện của sự thay đổi tốc độ.",
                            "Khác biệt mấu chốt: đường <b>thẳng</b> → tốc độ không đổi. Đường <b>cong</b> → tốc độ thay đổi. Hình dạng của đồ thị mã hoá thông tin về chất lượng chuyển động — không chỉ vị trí."
                        ]
                    }
                }
            ]
        },
        {
            "order_index": 3,
            "blocks": [
                {
                    "id": "quiz-l2-1",
                    "type": "quiz",
                    "content": {
                        "question": "Đồ thị $f(t)$ là đường thẳng. Kết luận gì về tốc độ?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Tốc độ bằng 0."
                            },
                            {
                                "value": "b",
                                "label": "Tốc độ không đổi."
                            },
                            {
                                "value": "c",
                                "label": "Tốc độ tăng dần."
                            },
                            {
                                "value": "d",
                                "label": "Không đủ thông tin."
                            }
                        ],
                        "correct": "b",
                        "explanation": "Đường thẳng = độ dốc không đổi = tốc độ không đổi."
                    }
                }
            ]
        },
        {
            "order_index": 4,
            "blocks": [
                {
                    "id": "quiz-l2-2",
                    "type": "quiz",
                    "content": {
                        "question": "Đồ thị $f(t)$ cong lên. Tốc độ đang:",
                        "options": [
                            {
                                "value": "a",
                                "label": "Giảm."
                            },
                            {
                                "value": "b",
                                "label": "Không đổi."
                            },
                            {
                                "value": "c",
                                "label": "Tăng — đường cong ngày càng dốc hơn."
                            },
                            {
                                "value": "d",
                                "label": "Bằng 0."
                            }
                        ],
                        "correct": "c",
                        "explanation": "Đường cong dốc dần = vật chuyển động nhanh dần = tốc độ tăng."
                    }
                }
            ]
        },
        {
            "order_index": 5,
            "blocks": [
                {
                    "id": "quiz-l2-3",
                    "type": "quiz",
                    "content": {
                        "question": "Vật A: $f(t) = 3t$. Vật B: $f(t) = 5t$. Vật nào nhanh hơn?",
                        "options": [
                            {
                                "value": "a",
                                "label": "A — hệ số nhỏ hơn."
                            },
                            {
                                "value": "b",
                                "label": "B — hệ số 5 > 3 nên dốc hơn."
                            },
                            {
                                "value": "c",
                                "label": "Bằng nhau vì cả hai đều thẳng."
                            },
                            {
                                "value": "d",
                                "label": "Không xác định."
                            }
                        ],
                        "correct": "b",
                        "explanation": "Tốc độ = độ dốc đường thẳng. B dốc hơn → B nhanh hơn."
                    }
                }
            ]
        },
        {
            "order_index": 6,
            "blocks": [
                {
                    "id": "quiz-l2-4",
                    "type": "quiz",
                    "content": {
                        "question": "Khi kéo thanh trượt gia tốc lên cao, điều gì xảy ra với đường cam?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Đường cam xoay, trở nên dốc hơn ở cuối đoạn."
                            },
                            {
                                "value": "b",
                                "label": "Đường cam dịch sang phải."
                            },
                            {
                                "value": "c",
                                "label": "Đường cam trở thành đường thẳng."
                            },
                            {
                                "value": "d",
                                "label": "Đường cam không đổi."
                            }
                        ],
                        "correct": "a",
                        "explanation": "Gia tốc lớn hơn → vật tăng tốc mạnh hơn → đường cong dốc dần nhanh hơn. Đường xanh không đổi vì nó là tốc độ đều cố định."
                    }
                }
            ]
        },
        {
            "order_index": 7,
            "blocks": [
                {
                    "id": "quiz-l2-5",
                    "type": "quiz",
                    "content": {
                        "question": "Nếu đồ thị nằm ngang ($f(t) =$ hằng số), tốc độ là bao nhiêu?",
                        "options": [
                            {
                                "value": "a",
                                "label": "Vô cùng lớn."
                            },
                            {
                                "value": "b",
                                "label": "1 m/s."
                            },
                            {
                                "value": "c",
                                "label": "0 m/s — vật đứng yên."
                            },
                            {
                                "value": "d",
                                "label": "Âm."
                            }
                        ],
                        "correct": "c",
                        "explanation": "Nằm ngang = độ dốc = 0 = vật đứng yên."
                    }
