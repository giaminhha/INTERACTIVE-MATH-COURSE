                            {
                                "value": "c",
                                "label": "4"
                            },
                            {
                                "value": "d",
                                "label": "Không xác định"
                            }
                        ],
                        "correct": "c",
                        "explanation": "$(x^2-4)/(x-2) = x+2$. Tại $x \\to 2$: $2 + 2 = 4$."
                    }
                }
            ]
        },
        {
