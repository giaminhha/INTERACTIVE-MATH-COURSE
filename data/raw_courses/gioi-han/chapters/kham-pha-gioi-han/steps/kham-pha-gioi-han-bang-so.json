                {
                    "id": "quiz-l1-4",
                    "type": "quiz",
                    "content": {
                        "question": "Nếu $g(x) = (x^2 - 4)/(x - 2)$, thì $\\lim_{x \\to 2} g(x) = $?",
                        "options": [
                            {
                                "value": "a",
                                "label": "0"
                            },
                            {
                                "value": "b",
                                "label": "2"
