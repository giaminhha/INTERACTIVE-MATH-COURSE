                            },
                            {
                                "value": "b",
                                "label": "Chia cho 0 — biểu thức là $0/0$"
                            },
                            {
                                "value": "c",
                                "label": "$x = 1$ nằm ngoài miền xác định"
                            },
                            {
                                "value": "d",
                                "label": "Kết quả quá lớn"
                            }
                        ],
                        "correct": "b",
                        "explanation": "Tử và mẫu đều bằng 0 tại $x = 1$, cho dạng $0/0$ — không xác định."
                    }
                }
            ]
        },
        {
