                            {
                                "value": "c",
                                "label": "1"
                            },
                            {
                                "value": "d",
                                "label": "0"
                            }
                        ],
                        "correct": "b",
                        "explanation": "$\\lim x^2 + \\lim 3x = 1 + 3 = 4$."
