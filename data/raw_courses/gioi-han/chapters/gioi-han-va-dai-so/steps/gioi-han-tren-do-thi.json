                            {
                                "value": "c",
                                "label": "2"
                            },
                            {
                                "value": "d",
                                "label": "Không tồn tại"
                            }
                        ],
                        "correct": "b",
                        "explanation": "Đường cong $y = x + 1$ tiến về $2 + 1 = 3$ tại $x = 2$."
                    }
                }
            ]
        },
