                                "label": "Kết luận giới hạn không tồn tại"
                            },
                            {
                                "value": "c",
                                "label": "Phân tích và rút gọn thừa số chung"
                            },
                            {
                                "value": "d",
                                "label": "Dùng máy tính"
                            }
                        ],
                        "correct": "c",
                        "explanation": "$0/0$ = bất định. Phải phân tích thừa số và rút gọn trước khi thế lại."
                    }
                }
            ]
        },
        {
            "order_index": 11,
