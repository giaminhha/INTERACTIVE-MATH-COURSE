                        "options": [
                            {
                                "value": "a",
                                "label": "Thoát ra ngoài biên"
                            },
                            {
                                "value": "b",
                                "label": "Bị ép phẳng về 0 — dao động bị triệt tiêu"
                            },
                            {
                                "value": "c",
                                "label": "Phát tán"
                            },
                            {
                                "value": "d",
                                "label": "Ngừng dao động"
                            }
                        ],
                        "correct": "b",
                        "explanation": "Thừa số $|x|^p$ → 0 khi $x \\to 0$, kẹp biên độ dao động về 0."
                    }
                }
            ]
        },
        {
