{
    "id": "gioi-han-tai-vo-cuc",
    "title": "Giới Hạn Tại Vô Cực",
    "description": "Hàm có thể ổn định ngay cả khi đầu vào tăng không giới hạn — tiệm cận ngang.",
    "xp_reward": 15,
    "order_index": 2,
